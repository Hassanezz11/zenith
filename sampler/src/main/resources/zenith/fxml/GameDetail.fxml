<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="atlantafx.sampler.zenith.GameDetailController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            styleClass="content-scroll">
    <VBox spacing="24" styleClass="screen-root">
        <padding>
            <Insets top="24" right="24" bottom="24" left="24"/>
        </padding>

        <SplitPane dividerPositions="0.68">
            <items>
                <!-- Left: info + reviews + review form -->
                <VBox spacing="16" styleClass="detail-pane">
                    <padding>
                        <Insets top="18" right="18" bottom="18" left="18"/>
                    </padding>
                    <Label fx:id="titleLabel" text="Game Title" styleClass="hero-title"/>
                    <Label fx:id="categoryLabel" text="Category" styleClass="muted-copy"/>
                    <Label fx:id="descriptionLabel" wrapText="true" styleClass="detail-copy"/>

                    <Label text="Reviews" styleClass="section-title"/>
                    <VBox fx:id="reviewsBox" spacing="14"/>

                    <Label text="Write a Review" styleClass="section-title"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="Rating" styleClass="filter-label"/>
                        <ComboBox fx:id="ratingBox" prefWidth="90"/>
                    </HBox>
                    <TextArea fx:id="reviewInput" promptText="Share your experience..."
                              prefRowCount="3" wrapText="true"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Button fx:id="submitReviewButton" text="Submit Review" styleClass="accent"/>
                        <Label fx:id="reviewStatusLabel" styleClass="muted-copy" wrapText="true"/>
                    </HBox>
                </VBox>

                <!-- Right: cover + action buttons -->
                <VBox spacing="14">
                    <styleClass>
                        <String fx:value="action-zone"/>
                        <String fx:value="elevated-1"/>
                    </styleClass>
                    <padding>
                        <Insets top="18" right="18" bottom="18" left="18"/>
                    </padding>
                    <ImageView fx:id="coverImage"/>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Action Zone" styleClass="filter-label"/>
                        <Region>
                            <HBox.hgrow>
                                <Priority fx:constant="ALWAYS"/>
                            </HBox.hgrow>
                        </Region>
                        <Label fx:id="priceLabel" styleClass="price-pill"/>
                    </HBox>
                    <Button fx:id="addToLibraryButton" text="Add to Library"
                            maxWidth="Infinity" styleClass="success"/>
                    <Button fx:id="addToWishlistButton" text="Add to Wishlist"
                            maxWidth="Infinity"/>
                    <Label fx:id="actionStatusLabel" styleClass="muted-copy" wrapText="true"/>
                </VBox>
            </items>
        </SplitPane>
    </VBox>
</ScrollPane>
