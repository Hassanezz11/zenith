<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/24"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="atlantafx.sampler.zenith.LibraryController"
      spacing="0" styleClass="screen-root">

    <TabPane fx:id="libraryTabs" tabClosingPolicy="UNAVAILABLE">
        <VBox.vgrow>
            <javafx.scene.layout.Priority fx:constant="ALWAYS"/>
        </VBox.vgrow>

        <Tab text="Owned Games">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll">
                <VBox spacing="16">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>
                    <Label text="Your Library" styleClass="page-title"/>
                    <Label text="Games you own" styleClass="muted-copy"/>
                    <FlowPane fx:id="ownedPane" hgap="20" vgap="20"/>
                    <Label fx:id="ownedEmpty" text="Your library is empty. Browse and add games!" styleClass="muted-copy"/>
                </VBox>
            </ScrollPane>
        </Tab>

        <Tab text="Wishlist">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll">
                <VBox spacing="16">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>
                    <Label text="Wishlist" styleClass="page-title"/>
                    <Label text="Games you want to buy" styleClass="muted-copy"/>
                    <FlowPane fx:id="wishlistPane" hgap="20" vgap="20"/>
                    <Label fx:id="wishlistEmpty" text="Your wishlist is empty." styleClass="muted-copy"/>
                </VBox>
            </ScrollPane>
        </Tab>
    </TabPane>
</VBox>
